{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "RoutineFlow",
    "Audience": "RoutineFlowClient",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "WeeklyNotification": {
    "DayOfWeek": "Monday",
    "Hour": 8,
    "CheckIntervalMinutes": 60
  },
  "GoalRetention": {
    "CheckIntervalMinutes": 1440
  }
}

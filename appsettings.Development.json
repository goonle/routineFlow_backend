{
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "WeeklyNotification": {
    "CheckIntervalMinutes": 1
  },
  "GoalRetention": {
    "CheckIntervalMinutes": 1
  }
}
